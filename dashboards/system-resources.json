        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "format": "time_series",
          "legendFormat": "Used RAM",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "format": "time_series",
          "legendFormat": "Available RAM",
          "refId": "B"
        }
      ],
      "title": "Memory",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line",
            "fillOpacity": 10, "gradientMode": "none", "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false, "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5,
