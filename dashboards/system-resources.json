        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "pluginVersion": "12.0.1",
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_avail_bytes{mountpoint=\"/\"}) / node_filesystem_size_bytes{mountpoint=\"/\"}",
          "format": "time_series",
          "legendFormat": "Disk /",
          "refId": "A"
        },
        {
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/home\"} - node_filesystem_avail_bytes{mountpoint=\"/home\"}) / node_filesystem_size_bytes{mountpoint=\"/home\"}",
          "format": "time_series",
          "legendFormat": "Disk /home",
          "refId": "B"
        }
      ],
      "title": "Disk Utilization",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
